# PostgreSQL connection string. For Prisma Postgres / hosted DB use sslmode=verify-full
# (avoids pg "SECURITY WARNING" about sslmode=require). Local dev: ?sslmode=disable
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=verify-full

# Required for NextAuth (sign-in / sessions). Generate: openssl rand -base64 32
# NEXTAUTH_SECRET=
# App URL for callbacks and cookies (no trailing slash). Example: http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000

# Redis — ioredis via `src/lib/redis-connection.ts` (singleton per purpose).
# Cache API: `src/lib/cache/` — redis-cache.ts, cache-keys.ts, cache-utils.ts
# Also used for rate limits and BullMQ (`npm run worker`).
# Use either a full URL or discrete host/port/password (URL takes precedence if both are set).
# If unset, caching and rate limits are in-memory only (per Node process).
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Job recommended candidates Redis cache (GET /api/jobs/[id]/recommended-candidates). Requires Redis.
# TTL seconds, clamped 900–1800 (15–30 min). Default 1200 (20 min).
# JOB_RECOMMENDED_CANDIDATES_CACHE_TTL_SEC=1200

# Shared AI `/embed` text cache (job + candidate embedding workers; keys `ats:v1:embed:vec:...`). Requires Redis.
# TTL seconds, clamped 300–604800 (5 min–7 days). Default 86400 (24h). Avoids repeat inference for identical semantic text.
# EMBEDDING_TEXT_CACHE_TTL_SEC=86400

# Recruiter semantic search Redis cache (POST /api/search/candidates, /api/candidates/semantic-search).
# Query embeddings + top hybrid results; keys use normalized query (ats:v1:search:...).
# TTL seconds, clamped 900–1800 (15–30 min). Default 1200 (20 min). Requires Redis.
# RECRUITER_SEARCH_CACHE_TTL_SEC=1200
# Legacy overrides (optional; default follows RECRUITER_SEARCH_CACHE_TTL_SEC):
# RECRUITER_SEARCH_EMBED_CACHE_TTL_SEC=1800

# Recruiter AI search rate limits (per authenticated user; sliding window; Redis when configured).
# RECRUITER_SEARCH_RATE_MAX=20
# RECRUITER_SEARCH_RATE_WINDOW_MS=60000
# RECRUITER_SEARCH_EMBED_RATE_MAX=10
# RECRUITER_SEARCH_EMBED_RATE_WINDOW_MS=60000

# Auth + uploads rate limits (sliding window; Redis when configured; in-memory fallback per node).
# AUTH_REGISTER_RATE_MAX=10
# AUTH_REGISTER_RATE_WINDOW_MS=60000
# AUTH_FORGOT_PASSWORD_RATE_MAX=5
# AUTH_FORGOT_PASSWORD_RATE_WINDOW_MS=60000
# AUTH_RESET_PASSWORD_RATE_MAX=10
# AUTH_RESET_PASSWORD_RATE_WINDOW_MS=60000
# AUTH_DEMO_LOGIN_RATE_MAX=30
# AUTH_DEMO_LOGIN_RATE_WINDOW_MS=60000
# RESUME_UPLOAD_RATE_MAX=5
# RESUME_UPLOAD_RATE_WINDOW_MS=60000

# AI candidate scoring thresholds (optional).
# You can override per job using `jobMeta` keys:
# - aiMinimumAcceptableScore
# - aiHighPriorityThreshold
# - aiAutoShortlistThreshold (future)
# AI_CANDIDATE_SCORING_MIN_ACCEPTABLE_SCORE=60
# AI_CANDIDATE_SCORING_HIGH_PRIORITY_THRESHOLD=75
# AI_CANDIDATE_SCORING_AUTO_SHORTLIST_THRESHOLD=90

# AI candidate scoring Redis cache (GET /api/jobs/[id]/candidate-scores). Requires Redis.
# Layers: pgvector semantic ranking, per-candidate hybrid fit (candidateFitScore), full result list.
# Invalidated on job/candidate profile or embedding changes (see candidate-scoring-cache.ts).
# CANDIDATE_SCORING_RESULTS_CACHE_TTL_SEC=300
# CANDIDATE_SCORING_SEMANTIC_CACHE_TTL_SEC=600
# CANDIDATE_SCORING_FIT_CACHE_TTL_SEC=600
# CANDIDATE_SCORING_POPULAR_CACHE_TTL_SEC=900
# CANDIDATE_SCORING_POPULAR_WINDOW_SEC=604800

# Interview scheduling conflict detection (POST /api/interviews). Uses interviewer UserProfile.timezone when set.
# INTERVIEW_SCHED_WORK_START_HOUR=8
# INTERVIEW_SCHED_WORK_END_HOUR=20
# INTERVIEW_SCHED_ALLOW_WEEKENDS=false

# Interview scheduling validation & abuse protection (POST /api/interviews, PATCH .../reschedule).
# INTERVIEW_SCHEDULE_MIN_LEAD_MINUTES=15
# INTERVIEW_SCHEDULE_MAX_HORIZON_DAYS=365
# INTERVIEW_MEETING_LINK_REQUIRE_HTTPS=false
# INTERVIEW_SCHEDULE_MAX_INTERVIEWERS=15
# INTERVIEW_SCHEDULE_MAX_ACTIVE_PER_APPLICATION=25
# INTERVIEW_SCHEDULE_MAX_CREATES_PER_APPLICATION_PER_DAY=15
# INTERVIEW_SCHEDULE_MAX_RESCHEDULES_PER_INTERVIEW_PER_DAY=10
# INTERVIEW_SCHEDULING_RATE_MAX=30
# INTERVIEW_SCHEDULING_RATE_WINDOW_MS=60000

# Interview email (BullMQ queue `ats-email`). Requires Redis + `npm run worker`.
# Lifecycle: interview_scheduled, interview_rescheduled, interview_cancelled, interview_panel_notice (immediate);
# interview_reminder + interview_reminder_interviewer (delayed 24h and 1h before scheduledAt).
# Wired from POST /api/interviews, PATCH .../reschedule, PATCH .../cancel (see interview-email-orchestration.ts).

# Dashboard analytics cache (GET /api/dashboard/summary, /charts, /api/pipeline/stats). Requires Redis.
# TTL in seconds; clamped to 300–900 (5–15 minutes). Default 600 (10 min).
# DASHBOARD_ANALYTICS_CACHE_TTL_SEC=600

# Activity feeds + notifications cache (short TTL; safe staleness, reduces DB load). Requires Redis.
# ACTIVITY_FEED_CACHE_TTL_SEC=10
# NOTIFICATIONS_FEED_CACHE_TTL_SEC=20
# NOTIFICATIONS_UNREAD_CACHE_TTL_SEC=15
# DASHBOARD_ACTIVITY_CACHE_TTL_SEC=15

# Cache analytics (Redis) — counts + hit/miss latency averages (used by GET /api/cache/analytics). Requires Redis.
# CACHE_ANALYTICS_TTL_SEC=604800

# Set to 0 / false / off to disable JSON telemetry logs for dashboard API routes (stdout).
# DASHBOARD_TELEMETRY=1

# Optional: override local resume storage directory (default: uploads/resumes under project root).
# Absolute path, or path relative to process.cwd().
# RESUME_UPLOAD_DIR=uploads/resumes

# Max resume upload size in bytes (default 5242880 = 5 MiB). Used by POST /api/resumes/upload and POST /api/candidates/[id]/resume.
# MAX_RESUME_BYTES=5242880

# Shared secret for GET/POST /api/cron/process-parse-jobs (resume parse worker). Required for that route.
# Vercel Cron sends Authorization: Bearer <CRON_SECRET> when this env var is set in the project.
# Local: curl -H "Authorization: Bearer your-secret" "http://localhost:3000/api/cron/process-parse-jobs"
# CRON_SECRET=

# Optional: duplicate suppression for in-app STAGE_CHANGED (same title+message+user within N ms). Default 120000 (2 min). Set to 0 to disable.
# NOTIFICATION_STAGE_DEDUP_WINDOW_MS=120000

# Optional: minimum matchScore (0–100) for GET /api/candidates/[id]/recommendations. Default 40 (see src/lib/recommendation-config.ts).
# RECOMMENDATION_MIN_MATCH_SCORE=40

# AI microservice — embeddings + similarity only (parsing runs in Node via OpenResume + Gemini).
# Use http://127.0.0.1:8000 when Next.js/workers run on the host (start-dev.sh).
# AI_SERVICE_URL=http://127.0.0.1:8000
# AI_EMBEDDING_MODEL=all-MiniLM-L6-v2
# Default skill-match threshold when job lists requiredSkills but no resumeMatchThreshold (default 60).
# DEFAULT_RESUME_MATCH_THRESHOLD=60
# Hybrid Gemini LLM parse (@google/genai in Node — see https://googleapis.github.io/js-genai/release_docs/index.html)
# GEMINI_API_KEY=your-key-from-google-ai-studio
# GOOGLE_API_KEY=   # alternative env name supported by @google/genai
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_RESUME_MAX_CHARS=14000
# AI_RESUME_LLM_ENABLED=true
# AI_RESUME_LLM_USE_AI_SERVICE=false
# AI_RESUME_LLM_TIMEOUT_MS=45000
# AI_RESUME_LLM_MIN_TEXT_CHARS=250
# Skip LLM when rule confidence >= threshold and contact+skills present (cost saver).
# AI_RESUME_LLM_SKIP_CONFIDENCE=0.92
# AI_RESUME_LLM_SKIP_HIGH_CONFIDENCE=true
# AI_RESUME_LLM_MAX_RETRIES=3
# AI_RESUME_LLM_RETRY_DELAY_MS=300000
# AI_RESUME_LLM_CB_FAILURES=5
# AI_RESUME_LLM_CB_OPEN_MS=120000

# ai-service: base directory for POST /parse-resume filePath (must match RESUME_UPLOAD_DIR on the ATS).
# RESUME_FILES_BASE_PATH=E:/Agile_Turn/recruitment system/app/uploads/resumes

# Postgres extensions (db side). `prisma migrate deploy` will run:
#   CREATE EXTENSION IF NOT EXISTS vector;
# Ensure your Postgres instance has pgvector installed/enabled.

# Bull Board queue monitor (separate Express process, default port 3030). ADMIN-only via signed token.
# `npm run dev` starts Next.js + monitor together. Manual: `npm run monitor` (monitor only).
# Next.js proxies /admin/queues → monitor in development (use NEXTAUTH_URL for the opened link).
# QUEUE_MONITOR_PORT=3030
# QUEUE_MONITOR_AUTO_START=false
# Override link target (default in dev: NEXTAUTH_URL or http://localhost:3000).
# QUEUE_MONITOR_PUBLIC_URL=http://localhost:3000

# BullMQ delayed jobs: second embedding pass after GET recommendations (default 90000 ms).
# RECOMMENDATION_EMBEDDING_RETRY_DELAY_MS=90000

# BullMQ rate limits — worker processing (per worker process, Redis-coordinated).
# QUEUE_EMBEDDING_WORKER_RATE_MAX=12
# QUEUE_EMBEDDING_WORKER_RATE_DURATION_MS=60000
# BullMQ email worker: max jobs started per window + parallel workers (SMTP pacing).
# QUEUE_EMAIL_WORKER_RATE_MAX=25
# QUEUE_EMAIL_WORKER_RATE_DURATION_MS=60000
# EMAIL_WORKER_CONCURRENCY=3
# Outbound SMTP caps before send (Redis sliding window; re-queues job when limited).
# EMAIL_OUTBOUND_GLOBAL_MAX=25
# EMAIL_OUTBOUND_GLOBAL_WINDOW_MS=60000
# EMAIL_OUTBOUND_RECIPIENT_MAX=5
# EMAIL_OUTBOUND_RECIPIENT_WINDOW_MS=3600000

# --- Email authentication (DNS — configure at your DNS host, not in .env) ---
# Use the domain in SMTP_FROM (e.g. example.com). Required for production deliverability.
#
# SPF (TXT @): which servers may send as your domain. Include your SMTP/API provider.
#   Example: v=spf1 include:amazonses.com include:sendgrid.net ~all
#
# DKIM (TXT selector._domainkey): public key from your provider after enabling DKIM signing.
#
# DMARC (TXT _dmarc): policy when SPF/DKIM fail + report address. Start with p=none, monitor rua.
#   Example: v=DMARC1; p=none; rua=mailto:dmarc-reports@example.com
#
# See src/lib/email/email-security.ts (EMAIL_AUTHENTICATION_PRACTICES) for full guidance.

# SMTP (nodemailer). Required: SMTP_HOST, SMTP_FROM. If SMTP_USER is set, SMTP_PASSWORD is required.
#
# Resend SMTP (https://resend.com/docs/send-with-smtp):
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASSWORD=re_xxxxxxxx   # Resend API key (password field)
# SMTP_FROM="Agile Turn <onboarding@resend.dev>"  # or your verified domain address
# EMAIL_SENDING_DOMAIN=resend.dev
# EMAIL_SEND_ENABLED=1
# RESEND_API_KEY=re_xxxxxxxx  # optional alias; nodemailer uses SMTP_PASSWORD
#
# Local Mailpit / catcher:
# SMTP_HOST=127.0.0.1
# SMTP_PORT=1025
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM="Recruitment Suite <noreply@example.com>"
# Optional: domain part of SMTP_FROM for startup alignment warnings (e.g. example.com).
# EMAIL_SENDING_DOMAIN=example.com
# Secrets: never commit SMTP_PASSWORD or provider API keys; use CI/secrets manager in production.
# Do not log env vars listed in EMAIL_SECRET_ENV_KEYS (see email-security.ts).
# Verify only (no sends): call verifySmtpConnection() from app code or a script.
# Enable worker sends: EMAIL_SEND_ENABLED=1
# Email worker retries: exponential backoff (default 3 retries, 5000ms base delay).
# EMAIL_JOB_MAX_RETRIES=3
# EMAIL_JOB_BACKOFF_DELAY_MS=5000

# Transactional email branding (templates/base-template.ts). Defaults use Agile Turn palette.
# EMAIL_BRAND_NAME=Agile Turn
# EMAIL_BRAND_TAGLINE=Recruitment Suite
# EMAIL_PRODUCT_NAME=Agile Turn Recruitment
# EMAIL_APP_URL=http://localhost:3000
# EMAIL_SUPPORT=support@example.com
# EMAIL_LOGO_URL=https://example.com/logo.png
# EMAIL_BRAND_PRIMARY=#0f766e
# IANA timezone for interview date/time in emails (default UTC). Example: Europe/London
# EMAIL_INTERVIEW_TIMEZONE=UTC
# Interview reminders: BullMQ delayed jobs at 24h and 1h before Application.interviewDate (see job-delay.ts).

# Queue analytics: JSON job lifecycle lines to stdout (disable: 0 / false / off).
# QUEUE_ANALYTICS_TELEMETRY=1

# Worker process: max ms to wait for active jobs on SIGTERM/SIGINT before force close (default 120000).
# WORKER_SHUTDOWN_TIMEOUT_MS=120000

# BullMQ rate limits — enqueue (API producers; sliding window, Redis when configured).
# QUEUE_EMBEDDING_ENQUEUE_RATE_MAX=120
# QUEUE_EMBEDDING_ENQUEUE_RATE_WINDOW_MS=60000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
