{
  "name": "recruitment-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.cjs",
    "dev": "cross-env QUEUE_MONITOR_AUTO_START=false node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev",
    "dev:all": "concurrently -k -n next,monitor -c blue,green \"cross-env QUEUE_MONITOR_AUTO_START=false node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev\" \"npx tsx monitor/server.ts\"",
    "dev:next": "node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev",
    "dev:monitor": "npx tsx monitor/server.ts",
    "dev:turbo": "node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev --turbo",
    "dev:clean": "node scripts/clean-next.cjs && node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "worker": "npx tsx workers/index.ts",
    "monitor": "npx tsx monitor/server.ts"
  },
  "dependencies": {
    "@bull-board/api": "^6.19.0",
    "@bull-board/express": "^6.19.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "mammoth": "^1.12.0",
    "next": "^15.0.0",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/express": "^4.17.21",
    "@types/node": "25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.5.8",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.2.1"
  }
}
