{
  "name": "recruitment-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.cjs",
    "dev": "node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev",
    "dev:stack": "concurrently -k -n next,worker -c blue,yellow \"node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev\" \"node --env-file=.env ./node_modules/.bin/tsx workers/index.ts\"",
    "dev:next": "node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev",
    "dev:turbo": "node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev --turbo",
    "dev:clean": "node scripts/clean-next.cjs && node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "worker": "node --env-file=.env ./node_modules/.bin/tsx workers/index.ts",
    "infra": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "infra:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "start-dev": "bash start-dev.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@getbrevo/brevo": "^6.0.2",
    "@google/genai": "^2.10.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.2",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.22.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.9",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "pdfkit": "^0.18.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.8",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.22.4",
    "typescript": "6.0.3"
  }
}
