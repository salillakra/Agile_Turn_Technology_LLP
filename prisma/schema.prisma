generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Application role for authorization (e.g. dashboard access, CRUD permissions).
enum Role {
  ADMIN
  RECRUITER
  HIRING_MANAGER
}

// Lifecycle of an open position: OPEN (accepting applications), PAUSED (on hold), CLOSED (filled or cancelled).
enum JobStatus {
  OPEN
  PAUSED
  CLOSED
}

// Pipeline stage for a candidate's application to a job.
enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW
  TECHNICAL
  FINAL_ROUND
  OFFER_SENT
  HIRED
  REJECTED
}

// Where the candidate was sourced from; used for funnel and channel analytics.
enum CandidateSource {
  LINKEDIN
  INDEED
  REFERRAL
  COMPANY_WEBSITE
  GLASSDOOR
  HEADHUNTER
  OTHER
}

// Async resume parsing pipeline: enqueue after upload; worker fills resultJson or error.
enum ResumeParseJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

enum ResumeParseStrategy {
  RULE_BASED
  LLM
  HYBRID
}

// Semantic embedding generation queue mirror (`embeddingQueue` BullMQ jobs).
enum EmbeddingJobEntityType {
  JOB
  CANDIDATE
}

enum EmbeddingJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// In-app notification category; used for filtering, analytics, and client routing.
enum NotificationType {
  CANDIDATE_CREATED
  APPLICATION_CREATED
  STAGE_CHANGED
  INTERVIEW_SCHEDULED
  OFFER_SENT
}

// Urgency for UI sorting, badges, and digest rules (API may expose lowercase strings).
enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
}

// Transactional email delivery lifecycle (`EmailLog` rows; mirrored from BullMQ worker).
enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
}

// Interview scheduling lifecycle for application interview rounds.
enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

// Panel role for an interviewer assigned to an interview round.
enum InterviewInterviewerRole {
  TECHNICAL_INTERVIEWER
  HIRING_MANAGER
  HR_INTERVIEWER
}

// Recommendation outcome from an interview round's feedback.
enum InterviewRecommendation {
  STRONG_HIRE
  HIRE
  NEUTRAL
  NO_HIRE
  STRONG_NO_HIRE
}

// What `reference_id` points to for in-app navigation (e.g. `/applicants?applicationId=` vs `?candidateId=`).
enum NotificationReferenceType {
  APPLICATION
  CANDIDATE
}

// Recruitment CRM — sales funnel and client commercial lifecycle.
enum CrmLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum CrmClientStatus {
  ACTIVE
  INACTIVE
}

enum CrmRequirementStatus {
  DRAFT
  OPEN
  ON_HOLD
  FILLED
  CANCELLED
}

enum CrmInvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

// Core identity: credentials (email/password) and app role. Required so NextAuth and the app
// have a single place for who is logged in and what they are allowed to do.
model User {
  id                       String                    @id @default(cuid())
  name                     String
  email                    String                    @unique
  emailVerified            DateTime?                 @map("email_verified")
  image                    String?
  password                 String?
  passwordResetToken       String?                   @unique @map("password_reset_token")
  passwordResetExpires     DateTime?                 @map("password_reset_expires")
  role                     Role                      @default(RECRUITER)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  accounts                 Account[]
  sessions                 Session[]
  notes                    Note[]
  candidateNotes           CandidateNote[]
  activityLogs             ActivityLog[]
  createdInterviews        Interview[]               @relation("InterviewCreatedBy")
  interviewAssignments     InterviewInterviewer[]
  interviewFeedbacks       InterviewFeedback[]       @relation("InterviewFeedbackReviewer")
  interviewScheduleChanges InterviewScheduleChange[] @relation("InterviewScheduleChangedBy")
  interviewCancellations   InterviewCancellation[]   @relation("InterviewCancelledBy")
  createdJobs              Job[]
  assignedJobLinks         JobAssignment[]
  reportExportLogs         ReportExportLog[]
  notifications            Notification[]
  /// Extended fields editable by the user (phone, bio, etc.). Created at registration or on first profile access.
  profile                  UserProfile?
  emailPreference          EmailPreference?
  crmLeadsOwned            CrmLead[]                 @relation("CrmLeadOwner")
  crmClientsOwned          CrmClient[]               @relation("CrmClientAccountOwner")
  crmRequirementsCreated   CrmRequirement[]          @relation("CrmRequirementCreator")
  updatedJobs              Job[]                     @relation("JobUpdatedBy")
  candidatesCreated        Candidate[]               @relation("CandidateCreatedBy")
  candidatesUpdated        Candidate[]               @relation("CandidateUpdatedBy")
  applicationsCreated      Application[]             @relation("ApplicationCreatedBy")
  applicationsUpdated      Application[]             @relation("ApplicationUpdatedBy")
  jobAssignmentsAssigned   JobAssignment[]           @relation("JobAssignmentAssigner")
  jobAssignmentsUpdated    JobAssignment[]           @relation("JobAssignmentUpdatedBy")
  tagsCreated              Tag[]                     @relation("TagCreatedBy")
  tagsUpdated              Tag[]                     @relation("TagUpdatedBy")
  candidateTagsCreated     CandidateTag[]            @relation("CandidateTagCreatedBy")
  candidateTagsUpdated     CandidateTag[]            @relation("CandidateTagUpdatedBy")
  candidateSkillsCreated   CandidateSkill[]          @relation("CandidateSkillCreatedBy")
  candidateSkillsUpdated   CandidateSkill[]          @relation("CandidateSkillUpdatedBy")
  candidateNotesUpdated    CandidateNote[]           @relation("CandidateNoteUpdatedBy")
  notesUpdated             Note[]                    @relation("NoteUpdatedBy")
  updatedInterviews        Interview[]               @relation("InterviewUpdatedBy")
  interviewInterviewersCreated InterviewInterviewer[] @relation("InterviewInterviewerCreatedBy")
  interviewInterviewersUpdated InterviewInterviewer[] @relation("InterviewInterviewerUpdatedBy")
  userProfilesCreated      UserProfile[]             @relation("UserProfileCreatedBy")
  userProfilesUpdated      UserProfile[]             @relation("UserProfileUpdatedBy")
  crmLeadsCreated          CrmLead[]                 @relation("CrmLeadCreatedBy")
  crmLeadsUpdated          CrmLead[]                 @relation("CrmLeadUpdatedBy")
  crmClientsCreated        CrmClient[]               @relation("CrmClientCreatedBy")
  crmClientsUpdated        CrmClient[]               @relation("CrmClientUpdatedBy")
  crmContactsCreated       CrmContact[]              @relation("CrmContactCreatedBy")
  crmContactsUpdated       CrmContact[]              @relation("CrmContactUpdatedBy")
  crmRequirementsUpdated   CrmRequirement[]          @relation("CrmRequirementUpdatedBy")
  crmSubmissionsCreated    CrmSubmission[]           @relation("CrmSubmissionCreatedBy")
  crmSubmissionsUpdated    CrmSubmission[]           @relation("CrmSubmissionUpdatedBy")
  crmClosuresCreated       CrmClosure[]              @relation("CrmClosureCreatedBy")
  crmClosuresUpdated       CrmClosure[]              @relation("CrmClosureUpdatedBy")
  crmInvoicesCreated       CrmInvoice[]              @relation("CrmInvoiceCreatedBy")
  crmInvoicesUpdated       CrmInvoice[]              @relation("CrmInvoiceUpdatedBy")
  invitesSent              UserInvite[]              @relation("UserInviteInviter")

  @@map("users")
}

// Invite token for onboarding new team members. ADMIN creates an invite; user registers via /invite/[token].
model UserInvite {
  id        String    @id @default(cuid())
  email     String
  role      Role
  token     String    @unique @default(cuid())
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  invitedBy String    @map("invited_by")
  inviter   User      @relation("UserInviteInviter", fields: [invitedBy], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("user_invites")
}

/// Per-user profile data (separate from auth core on `User`). One row per user after registration or lazy-created on first profile API access.
model UserProfile {
  userId         String   @id @map("user_id")
  phone          String?
  /// Optional contact email (not used for sign-in); `User.email` remains the login identity.
  personalEmail  String?  @map("personal_email")
  jobTitle       String?  @map("job_title")
  department     String?
  location       String?
  bio            String?  @db.Text
  timezone       String?
  /// Recruiter / hiring manager employer (staff profile).
  companyName    String?  @map("company_name")
  /// List of skill strings (JSON array), used for non-admin roles.
  skills         Json?
  experience     String?  @db.Text
  education      String?  @db.Text
  linkedInUrl    String?  @map("linkedin_url")
  githubUrl      String?  @map("github_url")
  portfolioUrl   String?  @map("portfolio_url")
  /// Local avatar blob file name under profile media dir (served via `/api/profile/media/...`).
  avatarFileName String?  @map("avatar_file_name")
  /// Arbitrary preferences (e.g. digest toggles) as JSON.
  preferences    Json?    @map("preferences")
  createdById    String?  @map("created_by_id")
  updatedById    String?  @map("updated_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy      User?    @relation("UserProfileCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy      User?    @relation("UserProfileUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([updatedById])
  @@map("user_profiles")
}

// In-app alerts for a user (e.g. stage changes, parse complete). Persisted for cross-session and multi-device delivery.
model Notification {
  id            String                     @id @default(cuid())
  userId        String                     @map("user_id")
  type          NotificationType
  title         String
  message       String                     @db.Text
  priority      NotificationPriority? // null = legacy rows or unspecified
  referenceId   String?                    @map("reference_id") // applicationId or candidateId
  referenceType NotificationReferenceType? @map("reference_type")
  isRead        Boolean                    @default(false) @map("is_read")
  createdAt     DateTime                   @default(now()) @map("created_at")
  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
  @@index([userId, priority])
  @@index([referenceType, referenceId])
  @@map("notifications")
}

// Links a User to an OAuth/OpenID provider (Google, GitHub, etc.). Required for OAuth sign-in:
// NextAuth stores provider id and tokens here so it can refresh access and identify the user.
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Server-side session record. Required so NextAuth can validate the session cookie (sessionToken)
// and load the user; expires supports secure session expiry.
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// One-time tokens for email verification or magic-link sign-in. Required so NextAuth can
// verify ownership of an email (e.g. sign-in link or verification link) and then invalidate the token.
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Open position in the recruitment system.
// Field rationale: id — unique reference; title — role name; department — team/org; location — where (remote/office);
// yearsOfExperience — filter/match candidates; description — full JD; additionalComments — internal notes;
// status — OPEN/PAUSED/CLOSED for pipeline; createdAt — audit; createdBy — ownership and audit.
// requiredSkills / preferredSkills — first-class arrays for job–candidate recommendation (see job-recommendation module).
// jobMeta.requiredSkills / jobMeta.preferredSkills remain until APIs are migrated to read/write these columns.
model Job {
  id                 String                 @id @default(cuid())
  title              String
  department         String
  location           String
  yearsOfExperience  Int?                   @map("years_of_experience")
  description        String?                @db.Text
  additionalComments String?                @map("additional_comments") @db.Text
  jobMeta            Json?                  @map("job_meta")
  /// Primary matching signal: candidate should meet most/all for a strong match; drives core matchScore.
  requiredSkills     String[]               @default([]) @map("required_skills")
  /// Secondary signal: extra points when present; absence does not disqualify a candidate.
  preferredSkills    String[]               @default([]) @map("preferred_skills")
  /// Cached semantic embedding from AI service (e.g. `{ "model": "all-MiniLM-L6-v2", "vector": number[] }`). Null until generated.
  embedding          Json?                  @map("embedding")
  /// pgvector embedding for similarity search (vector(384)); written alongside `embedding`.
  embeddingVector    Unsupported("vector")? @map("embedding_vector")
  embeddingUpdatedAt DateTime?              @map("embedding_updated_at")
  status             JobStatus              @default(OPEN)
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")
  createdBy          String                 @map("created_by")
  updatedById        String?                @map("updated_by_id")
  creator            User                   @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  updatedBy          User?                  @relation("JobUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  applications       Application[]
  assignments        JobAssignment[]
  crmRequirement     CrmRequirement?

  @@index([updatedById])
  @@map("jobs")
}

// Explicit assignment of a hiring manager user to a job.
// Used for HIRING_MANAGER-scoped report visibility.
model JobAssignment {
  id         String   @id @default(cuid())
  jobId      String   @map("job_id")
  userId     String   @map("user_id")
  assignedAt  DateTime @default(now()) @map("assigned_at")
  assignedById String? @map("assigned_by")
  updatedById  String? @map("updated_by_id")
  updatedAt    DateTime @updatedAt @map("updated_at")
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assigner     User?    @relation("JobAssignmentAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  updatedBy    User?    @relation("JobAssignmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([jobId, userId])
  @@index([userId])
  @@index([jobId])
  @@index([assignedById])
  @@index([updatedById])
  @@map("job_assignments")
}

// Audit trail when a user downloads a report export (CSV/XLSX/PDF). Supports compliance and incident review.
model ReportExportLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  role        String
  format      String
  exportType  String   @map("export_type")
  reportRange String   @map("report_range")
  jobId       String?  @map("job_id")
  department  String?
  rowCount    Int      @map("row_count")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("report_export_logs")
}

// Person in the talent pool; stores full profile for sourcing, screening, and offer tracking.
// Field purposes in an ATS:
//   id — unique reference.
//   candidateName, email, contactNumber — identity and contact.
//   vendor — agency/third party that supplied the candidate (vendor management).
//   date — sourcing or profile-creation date for reporting.
//   positionRole — target or applied role for matching.
//   totalExperience, relevantExperience — filter and match to job requirements (years).
//   currentDesignation, currentCompany — current employment context.
//   preferredWorkLocation — location fit vs job.
//   noticePeriod, lastWorkingDay — join timeline and capacity planning.
//   offerInHand — urgency and negotiation context.
//   pan — tax ID for compliance (e.g. India PAN).
//   dob — age/eligibility if needed.
//   currentCTC, expectedCTC — compensation band and offer alignment.
//   resumeUrl — URL/key to where the resume file is stored (object storage or CDN path); not the raw file.
//   resumeFileName — original upload file name for display/download (e.g. "Jane_Doe_CV.pdf").
//   candidateSource — channel attribution (LINKEDIN, REFERRAL, etc.) for funnel analytics.
//   rating — overall or default fit score.
//   skills / normalizedSkills — recommendation arrays (raw parse vs canonical tokens for matching).
//   summary / companies / education / certifications — structured NLP profile from resume parse (normalized).
//   createdAt, updatedAt — audit.
// Relations: applications (per-job pipeline), notes (internal comments), candidateSkills (legacy row-per-skill; kept until APIs migrate), candidateTags, activityLogs.
model Candidate {
  id                    String                 @id @default(cuid())
  candidateName         String                 @map("candidate_name")
  email                 String
  contactNumber         String?                @map("contact_number")
  vendor                String?
  date                  DateTime?              @map("date")
  positionRole          String?                @map("position_role")
  totalExperience       Int?                   @map("total_experience")
  relevantExperience    Int?                   @map("relevant_experience")
  currentDesignation    String?                @map("current_designation")
  currentCompany        String?                @map("current_company")
  preferredWorkLocation String?                @map("preferred_work_location")
  noticePeriod          String?                @map("notice_period")
  lastWorkingDay        DateTime?              @map("last_working_day")
  offerInHand           Boolean?               @map("offer_in_hand")
  pan                   String?
  dob                   DateTime?              @map("dob")
  currentCTC            Decimal?               @map("current_ctc") @db.Decimal(12, 2)
  expectedCTC           Decimal?               @map("expected_ctc") @db.Decimal(12, 2)
  resumeUrl             String?                @map("resume_url")
  resumeFileName        String?                @map("resume_file_name")
  candidateSource       CandidateSource?       @map("candidate_source")
  rating                Int?
  /// Raw skill strings from resume parse or manual entry (display + audit). e.g. "React.js", "Node JS".
  skills                String[]               @default([]) @map("skills")
  /// Canonical tokens for matching (same rules as `normalizeSkill` in resume-job-match). e.g. "react", "node js".
  normalizedSkills      String[]               @default([]) @map("normalized_skills")
  /// NLP structured one-liner (POST /parse-resume `summary`, rule-based).
  summary               String?                @db.Text
  /// Previous employers from resume parse (deduped display names).
  companies             String[]               @default([])
  /// Normalized education rows: `[{ degree, college, graduationYear }]`.
  education             Json?
  /// Professional certifications from resume parse (deduped labels).
  certifications        String[]               @default([])
  /// Cached semantic embedding from AI service (e.g. `{ "model": "all-MiniLM-L6-v2", "vector": number[] }`). Null until generated.
  embedding             Json?                  @map("embedding")
  /// pgvector embedding for similarity search (vector(384)); written alongside `embedding`.
  embeddingVector       Unsupported("vector")? @map("embedding_vector")
  embeddingUpdatedAt    DateTime?              @map("embedding_updated_at")
  createdById           String?                @map("created_by_id")
  updatedById           String?                @map("updated_by_id")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  createdBy             User?                  @relation("CandidateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy             User?                  @relation("CandidateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  applications          Application[]
  notes                 Note[]
  candidateNotes        CandidateNote[]
  candidateTags         CandidateTag[]
  candidateSkills       CandidateSkill[]
  activityLogs          ActivityLog[]
  resumeParseJobs       ResumeParseJob[]
  parsedResumes         ParsedResume[]
  emailPreference       EmailPreference?

  @@index([createdById])
  @@index([updatedById])
  @@map("candidates")
}

// Tracks background work to parse an uploaded resume into structured fields (e.g. skills, experience).
model ResumeParseJob {
  id                 String                @id @default(cuid())
  candidateId        String                @map("candidate_id")
  status             ResumeParseJobStatus  @default(PENDING)
  fileHash           String                @map("file_hash")
  /// Parsed payload: see `ResumeParseResult` in `src/lib/resume-parse-result.ts` (name, skills, experience).
  resultJson         Json?                 @map("result_json")
  error              String?               @db.Text
  bullmqJobId        String?               @map("bullmq_job_id")
  attemptCount       Int                   @default(0) @map("attempt_count")
  /// LLM enrichment retries when status is PARTIAL (rule-only result persisted).
  llmRetryCount      Int                   @default(0) @map("llm_retry_count")
  strategyUsed       ResumeParseStrategy?  @map("strategy_used")
  ruleConfidence     Float?                @map("rule_confidence")
  llmConfidence      Float?                @map("llm_confidence")
  disagreementFlags  String[]              @default([]) @map("disagreement_flags")
  startedAt          DateTime?             @map("started_at")
  completedAt        DateTime?             @map("completed_at")
  failedAt           DateTime?             @map("failed_at")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  candidate          Candidate             @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  parsedResumes      ParsedResume[]

  @@index([candidateId])
  @@index([status])
  @@map("resume_parse_jobs")
}

/// Audit row per parse strategy (rule / LLM / hybrid merged snapshot).
model ParsedResume {
  id               String              @id @default(cuid())
  candidateId      String              @map("candidate_id")
  resumeParseJobId String              @map("resume_parse_job_id")
  strategy         ResumeParseStrategy
  payload          Json
  confidence       Float?
  createdAt        DateTime            @default(now()) @map("created_at")
  candidate        Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  resumeParseJob   ResumeParseJob      @relation(fields: [resumeParseJobId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([resumeParseJobId])
  @@map("parsed_resumes")
}

/// Tracks `embeddingQueue` work per job or candidate (observability + debugging).
model EmbeddingJob {
  id           String                 @id @default(cuid())
  entityType   EmbeddingJobEntityType @map("entity_type")
  entityId     String                 @map("entity_id")
  status       EmbeddingJobStatus     @default(PENDING)
  bullmqJobId  String?                @map("bullmq_job_id")
  error        String?                @db.Text
  attemptCount Int                    @default(0) @map("attempt_count")
  startedAt    DateTime?              @map("started_at")
  completedAt  DateTime?              @map("completed_at")
  failedAt     DateTime?              @map("failed_at")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  @@unique([entityType, entityId])
  @@index([status])
  @@map("embedding_jobs")
}

// Links a candidate to a job in the recruitment pipeline; one row per candidate–job pair.
// Analytics/dashboard code treats all Application DateTime fields as UTC instants; use frontend for business-timezone display only.
model Application {
  id              String           @id @default(cuid())
  candidateId     String           @map("candidate_id")
  jobId           String           @map("job_id")
  stage           ApplicationStage @default(APPLIED)
  rating          Int?
  interviewDate   DateTime?        @map("interview_date")
  feedback        String?          @db.Text
  rejectionReason String?          @map("rejection_reason") @db.Text
  source          String?
  notes           String?
  appliedDate     DateTime         @default(now()) @map("applied_date")
  lastActivity    DateTime         @updatedAt @map("last_activity")
  offerSentAt     DateTime?        @map("offer_sent_at")
  hiredAt         DateTime?        @map("hired_at")
  withdrawnAt     DateTime?        @map("withdrawn_at")
  withdrawnReason String?          @map("withdrawn_reason") @db.Text
  version         Int              @default(0)
  createdById     String?          @map("created_by_id")
  updatedById     String?          @map("updated_by_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  candidate       Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdBy       User?            @relation("ApplicationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?            @relation("ApplicationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  activityLogs    ActivityLog[]
  interviews      Interview[]
  crmSubmission   CrmSubmission?
  crmClosure      CrmClosure?

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([jobId])
  @@index([stage])
  @@index([appliedDate])
  @@index([jobId, stage])
  @@index([withdrawnAt])
  @@index([createdById])
  @@index([updatedById])
  @@map("applications")
}

// One scheduled interview round for an application (Application → many Interviews).
model Interview {
  id              String          @id @default(cuid())
  applicationId   String          @map("application_id")
  title           String
  description     String?         @db.Text
  interviewType   String          @map("interview_type")
  scheduledAt     DateTime        @map("scheduled_at")
  durationMinutes Int             @map("duration_minutes")
  meetingLink     String?         @map("meeting_link")
  status          InterviewStatus @default(SCHEDULED)
  notes           String?         @db.Text
  createdBy       String          @map("created_by")
  updatedById     String?         @map("updated_by_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  application     Application               @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  creator         User                      @relation("InterviewCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)
  updatedBy       User?                     @relation("InterviewUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  interviewers    InterviewInterviewer[]
  feedback        InterviewFeedback[]
  scheduleHistory InterviewScheduleChange[]
  cancellation    InterviewCancellation?

  @@index([applicationId])
  @@index([scheduledAt])
  @@index([status])
  @@index([updatedById])
  @@map("interviews")
}

// Immutable cancellation record (soft cancel); interview row is retained with status CANCELLED.
model InterviewCancellation {
  id              String          @id @default(cuid())
  interviewId     String          @unique @map("interview_id")
  reason          String          @db.Text
  previousStatus  InterviewStatus @map("previous_status")
  scheduledAt     DateTime        @map("scheduled_at")
  durationMinutes Int             @map("duration_minutes")
  cancelledBy     String          @map("cancelled_by")
  cancelledAt     DateTime        @default(now()) @map("cancelled_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  canceller User      @relation("InterviewCancelledBy", fields: [cancelledBy], references: [id], onDelete: Cascade)

  @@index([cancelledBy])
  @@index([cancelledAt])
  @@map("interview_cancellations")
}

// Immutable audit trail for schedule changes (reschedules); do not overwrite scheduling history silently.
model InterviewScheduleChange {
  id                  String   @id @default(cuid())
  interviewId         String   @map("interview_id")
  fromScheduledAt     DateTime @map("from_scheduled_at")
  toScheduledAt       DateTime @map("to_scheduled_at")
  fromDurationMinutes Int      @map("from_duration_minutes")
  toDurationMinutes   Int      @map("to_duration_minutes")
  changedBy           String   @map("changed_by")
  changedAt           DateTime @default(now()) @map("changed_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  changer   User      @relation("InterviewScheduleChangedBy", fields: [changedBy], references: [id], onDelete: Cascade)

  @@index([interviewId])
  @@index([changedBy])
  @@index([changedAt])
  @@map("interview_schedule_changes")
}

// Many-to-many link: Interview ↔ User with a panel role (supports multiple interviewers per interview).
model InterviewInterviewer {
  id          String                   @id @default(cuid())
  interviewId String                   @map("interview_id")
  userId      String                   @map("user_id")
  role        InterviewInterviewerRole
  createdById String?                  @map("created_by_id")
  updatedById String?                  @map("updated_by_id")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("InterviewInterviewerCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("InterviewInterviewerUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([interviewId, userId])
  @@index([interviewId])
  @@index([userId])
  @@index([interviewId, role])
  @@index([createdById])
  @@index([updatedById])
  @@map("interview_interviewers")
}

// Interview feedback linked to an interview; supports multiple feedback entries (e.g., panel interviews).
model InterviewFeedback {
  id             String                  @id @default(cuid())
  interviewId    String                  @map("interview_id")
  reviewerId     String                  @map("reviewer_id")
  rating         Int?
  strengths      String?                 @db.Text
  weaknesses     String?                 @db.Text
  recommendation InterviewRecommendation
  notes          String?                 @db.Text
  submittedAt    DateTime                @default(now()) @map("submitted_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  reviewer  User      @relation("InterviewFeedbackReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@unique([interviewId, reviewerId])
  @@index([interviewId])
  @@index([reviewerId])
  @@map("interview_feedback")
}

model Tag {
  id            String         @id @default(cuid())
  name          String         @unique
  createdById   String?        @map("created_by_id")
  updatedById   String?        @map("updated_by_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  createdBy     User?          @relation("TagCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?          @relation("TagUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  candidateTags CandidateTag[]

  @@index([createdById])
  @@index([updatedById])
  @@map("tags")
}

model CandidateTag {
  id          String    @id @default(cuid())
  candidateId String    @map("candidate_id")
  tagId       String    @map("tag_id")
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdBy   User?     @relation("CandidateTagCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?     @relation("CandidateTagUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([candidateId, tagId])
  @@index([createdById])
  @@index([updatedById])
  @@map("candidate_tags")
}

// Tags a candidate with a skill; supports search and filtering by skill.
model CandidateSkill {
  id          String    @id @default(cuid())
  candidateId String    @map("candidate_id")
  skillName   String    @map("skill_name") @db.VarChar(200)
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdBy   User?     @relation("CandidateSkillCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?     @relation("CandidateSkillUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@index([updatedById])
  @@map("candidate_skills")
}

// Internal recruiter feedback on a candidate; supports collaboration and handoff.
model CandidateNote {
  id          String    @id @default(cuid())
  candidateId String    @map("candidate_id")
  note        String    @db.Text
  createdById String    @map("created_by")
  updatedById String?   @map("updated_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User?     @relation("CandidateNoteUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedById])
  @@map("candidate_notes")
}

model Note {
  id          String    @id @default(cuid())
  candidateId String    @map("candidate_id")
  createdById String    @map("author_id")
  updatedById String?   @map("updated_by_id")
  content     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  updatedBy   User?     @relation("NoteUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedById])
  @@map("notes")
}

// action examples: APPLICATION_CREATED, STAGE_CHANGE, FEEDBACK_ADDED, NOTES_UPDATED,
// APPLICATION_DELETED, RESUME_PARSE_STARTED, RESUME_PARSE_COMPLETED, RESUME_PARSE_FAILED,
// RESUME_PARSE_APPLIED_TO_CANDIDATE, NOTIFICATION_SENT (e.g. in-app STAGE_CHANGED alerts to stakeholders),
// EMAIL_SENT, EMAIL_FAILED, INTERVIEW_REMINDER_SENT (outbound email worker audit),
// RECOMMENDATION_GENERATED, RECOMMENDATION_ACCEPTED (candidate→job recommendations),
// CANDIDATE_RECOMMENDED, CANDIDATE_SHORTLISTED (job→candidate recommendations),
// AI_SEARCH_PERFORMED, CANDIDATE_AI_MATCHED (recruiter semantic search observability),
// RECRUITER_AI_SEARCH_EXECUTED, RECRUITER_AI_SEARCH_RESULT_CLICKED, RECRUITER_AI_SEARCH_SHORTLISTED,
// INTERVIEW_SCHEDULED, INTERVIEW_RESCHEDULED, INTERVIEW_CANCELLED, FEEDBACK_SUBMITTED (interview panel).
model ActivityLog {
  id            String       @id @default(cuid())
  applicationId String?      @map("application_id")
  candidateId   String?      @map("candidate_id")
  userId        String?      @map("user_id")
  /// Interview round id (logical ref to `Interview.id`; indexed for audit queries).
  interviewId   String?      @map("interview_id")
  /// Subject interviewer user id when applicable (e.g. feedback reviewer).
  interviewerId String?      @map("interviewer_id")
  action        String
  details       String?
  createdAt     DateTime     @default(now())
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  candidate     Candidate?   @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([applicationId])
  @@index([applicationId, createdAt])
  @@index([interviewId])
  @@index([interviewerId])
  @@index([createdAt])
  @@map("activity_logs")
}

// Outbound transactional email audit trail (enqueue → worker → SMTP).
model EmailLog {
  id            String              @id @default(cuid())
  recipient     String
  subject       String
  template      String
  status        EmailDeliveryStatus @default(PENDING)
  error         String?             @db.Text
  sentAt        DateTime?           @map("sent_at")
  messageId     String?             @map("message_id")
  bullmqJobId   String?             @unique @map("bullmq_job_id")
  applicationId String?             @map("application_id")
  /// Worker attempts observed (1 = first try); used for retry metrics.
  attemptCount  Int                 @default(1) @map("attempt_count")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([recipient])
  @@index([status])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([template, createdAt])
  @@map("email_logs")
}

// Per-inbox email channel opt-in/out (candidates by email; staff optionally linked via `userId`).
model EmailPreference {
  id                 String     @id @default(cuid())
  /// Normalized delivery address — primary lookup at enqueue time.
  email              String     @unique
  userId             String?    @unique @map("user_id")
  candidateId        String?    @unique @map("candidate_id")
  /// Pipeline stage update emails (`stage_update`, `stage_changed`).
  stageUpdates       Boolean    @default(true) @map("stage_updates")
  /// Delayed reminders (`interview_reminder`).
  interviewReminders Boolean    @default(true) @map("interview_reminders")
  /// Promotional / newsletter sends (`marketing_*` templates). Opt-in default false.
  marketingEmails    Boolean    @default(false) @map("marketing_emails")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")
  user               User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidate          Candidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("email_preferences")
}

// Pre-client sales lead (Lead → Prospect funnel entry).
model CrmLead {
  id                String        @id @default(cuid())
  companyName       String        @map("company_name")
  contactName       String        @map("contact_name")
  email             String?
  phone             String?
  source            String?
  status            CrmLeadStatus @default(NEW)
  notes             String?       @db.Text
  expectedValue     Decimal?      @map("expected_value") @db.Decimal(12, 2)
  ownerId           String?       @map("owner_id")
  createdById       String?       @map("created_by_id")
  updatedById       String?       @map("updated_by_id")
  convertedClientId String?       @unique @map("converted_client_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  owner             User?         @relation("CrmLeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdBy         User?         @relation("CrmLeadCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?         @relation("CrmLeadUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  convertedClient   CrmClient?    @relation("LeadConvertedClient", fields: [convertedClientId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([ownerId])
  @@index([createdById])
  @@index([updatedById])
  @@map("crm_leads")
}

// Signed customer account.
model CrmClient {
  id                String           @id @default(cuid())
  name              String
  industry          String?
  website           String?
  status            CrmClientStatus  @default(ACTIVE)
  accountOwnerId    String?          @map("account_owner_id")
  createdById       String?          @map("created_by_id")
  updatedById       String?          @map("updated_by_id")
  billingEmail      String?          @map("billing_email")
  billingAddress    String?          @map("billing_address") @db.Text
  notes             String?          @db.Text
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  accountOwner      User?            @relation("CrmClientAccountOwner", fields: [accountOwnerId], references: [id], onDelete: SetNull)
  createdBy         User?            @relation("CrmClientCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?            @relation("CrmClientUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  contacts          CrmContact[]
  requirements      CrmRequirement[]
  closures          CrmClosure[]
  invoices          CrmInvoice[]
  convertedFromLead CrmLead?         @relation("LeadConvertedClient")

  @@index([status])
  @@index([accountOwnerId])
  @@index([createdById])
  @@index([updatedById])
  @@map("crm_clients")
}

// Client-side contact person.
model CrmContact {
  id        String    @id @default(cuid())
  clientId  String    @map("client_id")
  name      String
  email     String?
  phone     String?
  title     String?
  isPrimary Boolean   @default(false) @map("is_primary")
  createdById String? @map("created_by_id")
  updatedById String? @map("updated_by_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  client    CrmClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("CrmContactCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?     @relation("CrmContactUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([createdById])
  @@index([updatedById])
  @@map("crm_contacts")
}

// Client requirement — maps 1:1 to ATS Job when activated.
model CrmRequirement {
  id          String               @id @default(cuid())
  clientId    String               @map("client_id")
  title       String
  description String?              @db.Text
  headcount   Int                  @default(1)
  feeType     String?              @map("fee_type")
  feeAmount   Decimal?             @map("fee_amount") @db.Decimal(12, 2)
  currency    String?              @default("INR")
  status      CrmRequirementStatus @default(DRAFT)
  jobId       String?              @unique @map("job_id")
  department  String?
  location    String?
  createdById String               @map("created_by_id")
  updatedById String?              @map("updated_by_id")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  client      CrmClient            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  job         Job?                 @relation(fields: [jobId], references: [id], onDelete: SetNull)
  createdBy   User                 @relation("CrmRequirementCreator", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy   User?                @relation("CrmRequirementUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  submissions CrmSubmission[]
  closures    CrmClosure[]

  @@index([clientId])
  @@index([status])
  @@index([updatedById])
  @@map("crm_requirements")
}

// CRM record when a candidate is submitted to a client requirement (links to Application).
model CrmSubmission {
  id            String         @id @default(cuid())
  requirementId String         @map("requirement_id")
  applicationId String         @unique @map("application_id")
  submittedAt   DateTime       @default(now()) @map("submitted_at")
  notes         String?        @db.Text
  createdById   String?        @map("created_by_id")
  updatedById   String?        @map("updated_by_id")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  requirement   CrmRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("CrmSubmissionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?          @relation("CrmSubmissionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([requirementId])
  @@index([createdById])
  @@index([updatedById])
  @@map("crm_submissions")
}

// Deal closure when placement is confirmed (Application HIRED).
model CrmClosure {
  id            String         @id @default(cuid())
  clientId      String         @map("client_id")
  requirementId String         @map("requirement_id")
  applicationId String         @unique @map("application_id")
  closedAt      DateTime       @default(now()) @map("closed_at")
  feeAmount     Decimal?       @map("fee_amount") @db.Decimal(12, 2)
  revenueAmount Decimal?       @map("revenue_amount") @db.Decimal(12, 2)
  currency      String?        @default("INR")
  notes         String?        @db.Text
  createdById   String?        @map("created_by_id")
  updatedById   String?        @map("updated_by_id")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  client        CrmClient      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  requirement   CrmRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  application   Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("CrmClosureCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?          @relation("CrmClosureUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  invoice       CrmInvoice?

  @@index([clientId])
  @@index([requirementId])
  @@index([createdById])
  @@index([updatedById])
  @@map("crm_closures")
}

// Revenue invoice linked to client (optionally from a closure).
model CrmInvoice {
  id            String           @id @default(cuid())
  clientId      String           @map("client_id")
  closureId     String?          @unique @map("closure_id")
  invoiceNumber String           @unique @map("invoice_number")
  amount        Decimal          @db.Decimal(12, 2)
  currency      String           @default("INR")
  status        CrmInvoiceStatus @default(DRAFT)
  dueDate       DateTime?        @map("due_date")
  paidAt        DateTime?        @map("paid_at")
  notes         String?          @db.Text
  createdById   String?          @map("created_by_id")
  updatedById   String?          @map("updated_by_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  client        CrmClient        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  closure       CrmClosure?      @relation(fields: [closureId], references: [id], onDelete: SetNull)
  createdBy     User?            @relation("CrmInvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy     User?            @relation("CrmInvoiceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([status])
  @@index([createdById])
  @@index([updatedById])
  @@map("crm_invoices")
}
