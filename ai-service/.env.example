# Copy to .env and adjust for local runs.
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Resume NLP (spaCy) — loaded once at worker startup via FastAPI lifespan.
# SPACY_MODEL_NAME=en_core_web_sm
# RESUME_NLP_ENABLED=true
# After pip install: python -m spacy download en_core_web_sm

# Base directory for POST /parse-resume filePath (prevents path traversal). Example (Windows):
# RESUME_FILES_BASE_PATH=E:/Agile_Turn/recruitment system/app/uploads/resumes
# SERVICE_API_KEY=change-me-for-service-to-service-auth
